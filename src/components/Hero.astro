---
interface Props { status?: string; }
const { status = 'Open to new product collaborations' } = Astro.props;
---
<section class="hero glass glass-pad" id="top">
  <div class="badge">
    <span class="dot" aria-hidden="true"></span>
    <span class="badge-text">{status}</span>
  </div>

  <h1>
    <span class="line">Devendra</span>
    <span class="line accent-text">Reddy<span class="cursor" aria-hidden="true"></span></span>
  </h1>

  <p class="lede">
    I build software products end-to-end — a hospital management system,
    a markets stack, a few things in between.
  </p>

  <div class="meta-row">
    <span class="meta-item mono">
      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      Hyderabad, IN
    </span>
    <span class="meta-item mono">
      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      2026
    </span>
  </div>

  <div class="cta-row">
    <a class="cta cta-primary" href="#projects">
      <span>See what I'm building</span>
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
    <a class="cta cta-ghost" href="mailto:mail@devendra.me">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><polyline points="3,7 12,13 21,7"/></svg>
      <span>mail@devendra.me</span>
    </a>
  </div>

  <ul class="socials">
    <li><a href="https://github.com/dev225reddys" aria-label="GitHub">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.8 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2.9-.3 2-.4 3-.4s2 .1 3 .4c2.2-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.9 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.5-1.5 7.8-5.8 7.8-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>
    </a></li>
    <li><a href="https://www.linkedin.com/in/dev225reddys" aria-label="LinkedIn">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.61 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>
    </a></li>
    <li><a href="https://twitter.com/dev225reddys" aria-label="Twitter / X">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </a></li>
    <li><a href="/resume.pdf" aria-label="Resume PDF">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="14" x2="15" y2="14"/><line x1="9" y1="18" x2="15" y2="18"/></svg>
    </a></li>
  </ul>

  <div class="hero-glow" aria-hidden="true"></div>
</section>

<style>
  .hero {
    padding: 3rem 2.25rem 2.5rem;
    overflow: hidden;
    isolation: isolate;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 6px 12px 6px 10px;
    background: rgba(124, 227, 255, 0.08);
    border: 1px solid rgba(124, 227, 255, 0.22);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    margin-bottom: 1.75rem;
    box-shadow: 0 0 0 1px rgba(124, 227, 255, 0.05) inset;
  }
  .dot {
    width: 6px; height: 6px; border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
    animation: pulse 2.2s ease-in-out infinite;
  }
  .badge-text { letter-spacing: -0.005em; }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.55; transform: scale(0.82); }
  }

  h1 {
    font-size: clamp(2.6rem, 7vw, 4.25rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    font-weight: 700;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }
  .line { display: inline-block; }
  .accent-text {
    background: linear-gradient(120deg, var(--accent) 0%, var(--accent-2) 55%, var(--accent-3) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    position: relative;
  }
  .cursor {
    display: inline-block;
    width: 3px;
    height: 0.85em;
    background: var(--accent);
    margin-left: 0.1em;
    transform: translateY(0.1em);
    border-radius: 1px;
    box-shadow: 0 0 12px var(--accent);
    animation: blink 1.1s steps(1) infinite;
    vertical-align: baseline;
  }
  @keyframes blink {
    0%, 50% { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }

  .lede {
    font-size: 1.15rem;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 36ch;
    margin-bottom: 1.75rem;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    margin-bottom: 2rem;
  }
  .meta-item {
    display: inline-flex; align-items: center; gap: 0.45rem;
    color: var(--ink-muted);
  }
  .meta-item svg { color: var(--ink-faint); }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 10px 16px;
    border-radius: 999px;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    transition: transform 160ms ease, background 160ms ease, color 160ms ease, box-shadow 240ms ease;
  }
  .cta:hover { transform: translateY(-1px); }
  .cta-primary {
    color: #06070D;
    background: linear-gradient(120deg, var(--accent), var(--accent-2));
    box-shadow:
      0 1px 0 rgba(255,255,255,0.4) inset,
      0 8px 24px -6px rgba(124, 227, 255, 0.45);
  }
  .cta-primary:hover {
    color: #06070D;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.55) inset,
      0 12px 32px -6px rgba(179, 136, 255, 0.55);
  }
  .cta-ghost {
    color: var(--ink);
    background: var(--bg-elev-1);
    border: 1px solid var(--edge);
  }
  .cta-ghost:hover {
    color: var(--ink);
    background: var(--bg-elev-2);
  }

  .socials {
    display: flex;
    gap: 0.4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--edge);
  }
  .socials a {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    color: var(--ink-muted);
    background: var(--bg-elev-1);
    border: 1px solid var(--edge);
    transition: color 160ms ease, background 160ms ease, transform 160ms ease;
  }
  .socials a:hover {
    color: var(--ink);
    background: var(--bg-elev-2);
    transform: translateY(-1px);
  }

  .hero-glow {
    position: absolute;
    top: -120px;
    right: -120px;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(closest-side, rgba(124, 227, 255, 0.35), transparent 70%);
    filter: blur(40px);
    z-index: -1;
    pointer-events: none;
  }

  @media (max-width: 600px) {
    .hero { padding: 2rem 1.4rem 1.75rem; }
    h1 { font-size: 2.6rem; }
    .lede { font-size: 1.05rem; }
  }
</style>
